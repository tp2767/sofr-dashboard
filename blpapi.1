"""
SOFR Volatility Dashboard
Method: Daily range (High - Low) averaged over 20-day rolling window.
Summary row at top of each sheet shows current 20D avg range.
Run daily with Bloomberg Terminal open.
"""
 
import blpapi
import pandas as pd
import numpy as np
from openpyxl import Workbook
from openpyxl.styles import Font, PatternFill, Alignment, Border, Side
from openpyxl.utils import get_column_letter
from datetime import datetime, timedelta
 
# ── Tickers ───────────────────────────────────────────────────────────────────
TICKERS = {
    "1Y1Y Swap":   "S0042FS 1Y1Y BLC Curncy",
    "2Y2Y Swap":   "S0042FS 2Y2Y BLC Curncy",
    "5Y5Y Swap":   "S0042FS 5Y5Y BLC Curncy",
    "10Y10Y Swap": "S0042FS 10Y10Y BLC Curncy",
    "SFR5":        "SFR5 Comdty",
    "SFR9":        "SFR9 Comdty",
    "SFR13":       "SFR 13 Comdty",
}
 
FIELDS         = ["PX_HIGH", "PX_LOW"]
ROLLING_WINDOW = 20
OUTPUT_FILE    = "SOFR_Vol_Dashboard.xlsx"
 
# ── Bloomberg ─────────────────────────────────────────────────────────────────
def start_session():
    opts = blpapi.SessionOptions()
    opts.setServerHost("localhost")
    opts.setServerPort(8194)
    session = blpapi.Session(opts)
    if not session.start():
        raise RuntimeError("Failed to start Bloomberg session. Is Terminal running?")
    if not session.openService("//blp/refdata"):
        raise RuntimeError("Failed to open //blp/refdata service.")
    return session
 
def fetch_historical(session, tickers, start_date, end_date):
    refdata = session.getService("//blp/refdata")
    request = refdata.createRequest("HistoricalDataRequest")
    for t in tickers:
        request.getElement("securities").appendValue(t)
    for f in FIELDS:
        request.getElement("fields").appendValue(f)
    request.set("startDate", start_date.strftime("%Y%m%d"))
    request.set("endDate",   end_date.strftime("%Y%m%d"))
    request.set("periodicitySelection", "DAILY")
    session.sendRequest(request)
 
    data = {t: {} for t in tickers}
    while True:
        event = session.nextEvent(500)
        for msg in event:
            if msg.hasElement("securityData"):
                sec  = msg.getElement("securityData")
                tkr  = sec.getElementAsString("security")
                rows = sec.getElement("fieldData")
                for i in range(rows.numValues()):
                    row  = rows.getValue(i)
                    date = row.getElementAsDatetime("date").date()
                    hi   = row.getElementAsFloat("PX_HIGH") if row.hasElement("PX_HIGH") else np.nan
                    lo   = row.getElementAsFloat("PX_LOW")  if row.hasElement("PX_LOW")  else np.nan
                    data[tkr][date] = {"PX_HIGH": hi, "PX_LOW": lo}
        if event.eventType() == blpapi.Event.RESPONSE:
            break
    return data
 
# ── Build per-instrument DataFrame ────────────────────────────────────────────
def build_instrument_df(raw_dates):
    records = []
    for date, vals in sorted(raw_dates.items()):
        hi  = vals["PX_HIGH"]
        lo  = vals["PX_LOW"]
        rng = hi - lo if (pd.notna(hi) and pd.notna(lo)) else np.nan
        records.append({"Date": pd.Timestamp(date), "High": hi, "Low": lo, "Daily Range": rng})
    df = pd.DataFrame(records).set_index("Date")
    df["20D Avg Range"] = df["Daily Range"].rolling(ROLLING_WINDOW).mean()
    return df
 
# ── Styles ────────────────────────────────────────────────────────────────────
NAVY       = "1F3864"
LIGHT_BLUE = "DCE6F1"
GOLD       = "C9A84C"
WHITE      = "FFFFFF"
DARK_GREY  = "404040"
LIGHT_GREY = "F2F2F2"
 
def thin_border():
    s = Side(style="thin", color="BFBFBF")
    return Border(left=s, right=s, top=s, bottom=s)
 
def header_style(cell, bg=NAVY, fg=WHITE):
    cell.font      = Font(name="Arial", bold=True, color=fg, size=10)
    cell.fill      = PatternFill("solid", start_color=bg)
    cell.alignment = Alignment(horizontal="center", vertical="center")
    cell.border    = thin_border()
 
def body_style(cell, row_idx):
    bg = LIGHT_BLUE if row_idx % 2 == 0 else WHITE
    cell.font      = Font(name="Arial", size=10)
    cell.fill      = PatternFill("solid", start_color=bg)
    cell.alignment = Alignment(horizontal="right")
    cell.border    = thin_border()
 
def safe_val(val):
    if isinstance(val, str):
        return val
    try:
        return "" if pd.isna(val) else round(float(val), 4)
    except Exception:
        return ""
 
# ── Write one sheet per instrument ───────────────────────────────────────────
def write_instrument_sheet(wb, label, df):
    ws = wb.create_sheet(title=label)
    run_date    = datetime.today().strftime("%Y-%m-%d")
    valid_vol   = df["20D Avg Range"].dropna()
    current_20d = valid_vol.iloc[-1] if len(valid_vol) > 0 else np.nan
 
    # Row 1: Title
    ws.merge_cells("A1:E1")
    ws["A1"] = f"{label}  |  Updated: {run_date}"
    ws["A1"].font      = Font(name="Arial", bold=True, size=13, color=NAVY)
    ws["A1"].alignment = Alignment(horizontal="left", vertical="center")
    ws.row_dimensions[1].height = 24
 
    # Row 2: Current 20D callout
    ws.merge_cells("A2:B2")
    ws["A2"] = "Current 20D Avg Range:"
    ws["A2"].font      = Font(name="Arial", bold=True, size=11, color=DARK_GREY)
    ws["A2"].alignment = Alignment(horizontal="left", vertical="center")
    ws["A2"].fill      = PatternFill("solid", start_color=LIGHT_GREY)
    ws["A2"].border    = thin_border()
 
    ws["C2"] = round(current_20d, 4) if pd.notna(current_20d) else "N/A"
    ws["C2"].font          = Font(name="Arial", bold=True, size=14, color=GOLD)
    ws["C2"].alignment     = Alignment(horizontal="center", vertical="center")
    ws["C2"].fill          = PatternFill("solid", start_color=LIGHT_GREY)
    ws["C2"].number_format = "0.0000"
    ws["C2"].border        = thin_border()
    ws.row_dimensions[2].height = 28
 
    # Row 3: spacer
    ws.row_dimensions[3].height = 6
 
    # Row 4: Headers
    headers = ["Date", "High", "Low", "Daily Range (Hi-Lo)", "20D Avg Range"]
    for col_idx, h in enumerate(headers, start=1):
        cell = ws.cell(row=4, column=col_idx, value=h)
        header_style(cell)
    ws.row_dimensions[4].height = 30
 
    # Rows 5+: Data (newest first)
    for row_offset, (date, row) in enumerate(df.iloc[::-1].iterrows()):
        excel_row = row_offset + 5
        vals = [
            date.strftime("%Y-%m-%d"),
            row["High"],
            row["Low"],
            row["Daily Range"],
            row["20D Avg Range"],
        ]
        for col_idx, val in enumerate(vals, start=1):
            cell       = ws.cell(row=excel_row, column=col_idx)
            cell.value = val if col_idx == 1 else safe_val(val)
            body_style(cell, excel_row)
            if col_idx == 1:
                cell.alignment = Alignment(horizontal="center")
            if col_idx > 1 and isinstance(cell.value, float):
                cell.number_format = "0.0000"
 
    col_widths = [14, 12, 12, 22, 18]
    for i, w in enumerate(col_widths, start=1):
        ws.column_dimensions[get_column_letter(i)].width = w
 
    ws.freeze_panes = "A5"
 
# ── Summary sheet ─────────────────────────────────────────────────────────────
def write_summary_sheet(wb, summary_data):
    ws = wb.active
    ws.title = "Summary"
    run_date = datetime.today().strftime("%Y-%m-%d")
 
    ws.merge_cells("A1:C1")
    ws["A1"] = f"SOFR Vol Dashboard  —  Current 20D Avg Range  |  {run_date}"
    ws["A1"].font      = Font(name="Arial", bold=True, size=13, color=NAVY)
    ws["A1"].alignment = Alignment(horizontal="left", vertical="center")
    ws.row_dimensions[1].height = 26
 
    for col_idx, h in enumerate(["Instrument", "Current 20D Avg Range", "Category"], start=1):
        cell = ws.cell(row=2, column=col_idx, value=h)
        header_style(cell)
    ws.row_dimensions[2].height = 30
 
    categories = {
        "1Y1Y Swap":   "Swap Rate",    "2Y2Y Swap":  "Swap Rate",
        "5Y5Y Swap":   "Swap Rate",    "10Y10Y Swap": "Swap Rate",
        "SFR5":        "SOFR Futures", "SFR9":        "SOFR Futures",
        "SFR13":       "SOFR Futures",
    }
 
    for r, (label, val) in enumerate(summary_data.items(), start=3):
        fill = LIGHT_BLUE if r % 2 == 0 else WHITE
        display_val = round(val, 4) if pd.notna(val) else "N/A"
        for c, v in enumerate([label, display_val, categories.get(label, "")], start=1):
            cell            = ws.cell(row=r, column=c, value=v)
            cell.fill       = PatternFill("solid", start_color=fill)
            cell.alignment  = Alignment(horizontal="right" if c == 2 else "left")
            cell.border     = thin_border()
            if c == 2 and isinstance(v, float):
                cell.font          = Font(name="Arial", size=11, bold=True, color=GOLD)
                cell.number_format = "0.0000"
            else:
                cell.font = Font(name="Arial", size=10)
 
    for col, width in zip(["A", "B", "C"], [18, 24, 16]):
        ws.column_dimensions[col].width = width
    ws.freeze_panes = "A3"
 
# ── Main ──────────────────────────────────────────────────────────────────────
def main():
    end_date   = datetime.today()
    start_date = end_date - timedelta(days=365 * 5 + 30)
 
    print("Connecting to Bloomberg...")
    session = start_session()
 
    print("Fetching 5 years of Hi/Lo data...")
    raw = fetch_historical(session, list(TICKERS.values()), start_date, end_date)
    session.stop()
 
    print("Building workbook...")
    wb = Workbook()
 
    summary_data = {}
    for label, ticker in TICKERS.items():
        df          = build_instrument_df(raw.get(ticker, {}))
        valid_vol   = df["20D Avg Range"].dropna()
        summary_data[label] = valid_vol.iloc[-1] if len(valid_vol) > 0 else np.nan
        write_instrument_sheet(wb, label, df)
 
    write_summary_sheet(wb, summary_data)
    wb.move_sheet("Summary", offset=-len(wb.sheetnames) + 1)
 
    wb.save(OUTPUT_FILE)
    print(f"Done. Saved: {OUTPUT_FILE}")
 
if __name__ == "__main__":
    main()
